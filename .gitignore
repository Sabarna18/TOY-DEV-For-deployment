# =========================================================
# Root .gitignore
# FastAPI + React + Docker
# =========================================================

###########################################################
# PYTHON
###########################################################

__pycache__/
*.py[cod]
*$py.class

*.so
*.egg
*.egg-info/
.eggs/

build/
dist/
pip-wheel-metadata/

###########################################################
# VIRTUAL ENVIRONMENTS
###########################################################

.venv/
venv/
env/
ENV/

###########################################################
# PYTHON VERSION
###########################################################

.python-version

###########################################################
# UV
###########################################################

# Keep uv.lock committed for reproducible builds.
# Uncomment if you intentionally don't want it.
# uv.lock

###########################################################
# PYTHON TOOLS
###########################################################

.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/

.coverage
.coverage.*
coverage.xml
htmlcov/

###########################################################
# JUPYTER
###########################################################

.ipynb_checkpoints/

###########################################################
# DATABASES
###########################################################

*.db
*.sqlite
*.sqlite3

###########################################################
# LOGS
###########################################################

logs/
*.log

###########################################################
# ENVIRONMENT VARIABLES
###########################################################

.env
.env.*
!.env.example
production.env

###########################################################
# FASTAPI
###########################################################

instance/

###########################################################
# NODE / REACT / VITE
###########################################################

node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

###########################################################
# FRONTEND BUILD OUTPUT
###########################################################

dist/
build/

###########################################################
# VITE
###########################################################

.vite/

###########################################################
# TYPESCRIPT
###########################################################

*.tsbuildinfo

###########################################################
# TEST OUTPUT
###########################################################

test-results/
playwright-report/

###########################################################
# DOCKER
###########################################################

docker-compose.override.yml

###########################################################
# IDE
###########################################################

.vscode/
.idea/

*.iml

###########################################################
# OS FILES
###########################################################

.DS_Store
Thumbs.db

###########################################################
# TEMP FILES
###########################################################

*.tmp
*.temp
*.swp
*.swo
*~

###########################################################
# CACHES
###########################################################

.cache/

###########################################################
# LOCAL RUNTIME FILES
###########################################################

*.pid

###########################################################
# SECRETS
###########################################################

*.pem
*.key
*.crt

###########################################################
# MISC
###########################################################

.envrc
.direnv/

###########################################################
# OPTIONAL
###########################################################

# Ignore local uploads/storage if your app generates them
uploads/
media/
staticfiles/